# .env.example — Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's in .gitignore.
#
# Usage: cp .env.example .env

# ---------------------------------------------------------------------------
# Discord — Required for the bot to connect
# ---------------------------------------------------------------------------

# From discord.com/developers → Your App → Bot → Token
DISCORD_BOT_TOKEN=

# Right-click your Discord server → Copy Server ID
# (Requires Developer Mode: Discord Settings → Advanced → Developer Mode)
DISCORD_GUILD_ID=

# Channel ID where the heartbeat sends alerts (optional — bot stays quiet if unset)
# Right-click a channel → Copy Channel ID
DISCORD_HEARTBEAT_CHANNEL=

# ---------------------------------------------------------------------------
# Claude routing — Works with Claude Max subscription via Claude Code
# ---------------------------------------------------------------------------

# Set to true to route through the local Claude Code SDK proxy
# Set to false to use ANTHROPIC_API_KEY directly (requires paid API access)
OPENCLAW_USE_SDK=true

# Local proxy URL (Claude Code starts this automatically when you run "claude")
# Only used when OPENCLAW_USE_SDK=true
OPENCLAW_PROXY_URL=http://127.0.0.1:3456

# Direct API key (only needed when OPENCLAW_USE_SDK=false)
# Get from console.anthropic.com
# ANTHROPIC_API_KEY=

# Model to use for the main agent
MODEL_NAME=claude-sonnet-4-6

# Model to use for the autoresearch judge (can be a cheaper model)
JUDGE_MODEL=claude-sonnet-4-6

# Max tokens per agent response
MAX_TOKENS=4096

# ---------------------------------------------------------------------------
# Optional — Enhanced capabilities
# ---------------------------------------------------------------------------

# Perplexity API for web search in heartbeats and daily briefs
# Get from perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# How often the heartbeat fires (in minutes, default 30)
HEARTBEAT_INTERVAL_MINUTES=30
