# .gitignore — Files that should never be committed

# Environment / secrets
.env
*.env.local

# Python
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Workspace — personal config (templates/ contains safe defaults; workspace/ is yours)
workspace/SOUL.md
workspace/USER.md
workspace/AGENTS.md
workspace/DIRECTIVE.md
workspace/persona_routing.json
workspace/souls/

# Memory files — personal data, not for git
workspace/memory/*.md
workspace/memory/*.txt
workspace/memory/*.log
# (keep workspace/memory/.gitkeep)
!workspace/memory/.gitkeep

# Autoresearch logs — generated at runtime
workspace/autoresearch/logs/*.jsonl
!workspace/autoresearch/logs/.gitkeep

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
